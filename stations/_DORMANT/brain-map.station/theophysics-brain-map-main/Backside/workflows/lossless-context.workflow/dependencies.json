{
  "schema": "theophysics.workflow.dependencies.v1",
  "workflow": "lossless-context",
  "stations": [
    "markdown-parse",
    "block-classify",
    "semantic-address",
    "audit-snapshot",
    "postgres-store"
  ],
  "models": [
    "M-EMB-GEN-001",
    "DeBERTa-NLI optional",
